# MSW (Mock Service Worker) opt-in
# Set to "1" to intercept /api/v1/* requests with in-memory mocks during dev.
# Future Faz 12 will use real backend — just unset this flag.
# VITE_USE_MSW=1

# Wave F35 / Faz 1C — PersonaSwitcher (cross-app demo).
# Set VITE_DEMO_MODE=true to enable the persona switcher in the header
# (Ctrl+Shift+P shortcut). The 3 URL vars point to sibling apps so
# selecting a persona redirects to the correct host.
# VITE_DEMO_MODE=true
# VITE_APP_PUBLIC_URL=http://localhost:5180
# VITE_APP_BROKER_URL=http://localhost:5174
# VITE_APP_OPS_URL=http://localhost:5181
