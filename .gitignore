# Build / tooling caches
.turbo
*.tsbuildinfo
*.log
.eslintcache
.parcel-cache
.cache

# Test caches & coverage
coverage
.vitest-cache
.nyc_output

# Playwright RESULTS (transient)
test-results/
playwright-report/
playwright/.cache/
.last-run.json

# Playwright SNAPSHOTS (commit baselines for visual regression)
# Playwright defaults to tests/e2e/<spec>.spec.ts-snapshots/ — do NOT ignore.
!tests/e2e/**-snapshots/
!tests/e2e/**-snapshots/**

# Bundle analyzer artifact (only generated when ANALYZE=1)
dist/stats.html

# MSW (Mock Service Worker)
# public/mockServiceWorker.js is generated by `pnpm run msw:init` and MUST be committed.
# Vite serves it from /public/. Do NOT ignore it.
!public/mockServiceWorker.js
